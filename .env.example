# =================================================================
# Typhoon — environment template
# Copy to `.env.local` for development. NEVER commit real secrets.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others stay on the server (Vercel: do NOT mark them "Public").
# =================================================================

# --- Public Supabase values (browser + server) -------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only secrets — never expose in the browser -----------
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=

# --- Mail --------------------------------------------------------
# Booking submissions are mailed to BOOKING_EMAIL via Resend.
# WEBSITE_FROM_EMAIL must be a domain verified inside Resend.
BOOKING_EMAIL=booking@typhoon.band
WEBSITE_FROM_EMAIL=website@typhoon.band

# --- Site --------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://typhoon.band
